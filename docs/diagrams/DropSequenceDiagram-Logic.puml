@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant "d:DropCommand" as DropCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("drop")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("drop")
activate AddressBookParser

create DropCommand
AddressBookParser -> DropCommand
activate DropCommand

DropCommand --> AddressBookParser
deactivate DropCommand

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> DropCommand : execute(Model)
activate DropCommand

DropCommand -> Model : getFilteredApplicationList()
activate Model
Model --> DropCommand : filteredApplicationList
deactivate Model

DropCommand -> DropCommand : filter rejected/withdrawn applications

DropCommand -> Model : deleteApplications(applicationsToDelete)
activate Model
Model --> DropCommand
deactivate Model

DropCommand --> LogicManager : result
deactivate DropCommand
DropCommand -[hidden]-> LogicManager : result
destroy DropCommand

[<-- LogicManager
deactivate LogicManager
@enduml